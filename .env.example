# .env.example (*FR:Brunel*)
# Copy this to .env and fill in your values.
# .env is gitignored — never commit credentials.

# GitHub personal access token for git clone/pull/push inside the container.
# Required scopes: repo (read + write)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional overrides (defaults shown)
# REPO_URL=https://github.com/mitselek/ai-teams.git
# GIT_USER_NAME=mitselek
# GIT_USER_EMAIL=mihkel.putrinsh@gmail.com
