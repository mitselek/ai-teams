# xireactor-pilot — .env.example
#
# Copy to .env and fill in real values.
# .env is gitignored; NEVER commit real credentials.
#
# See xireactor-pilot-host-architecture-2026-04-15.md §1.1 for the full
# parameterization contract and §5.1 for credential classes.

# --- Identity -----------------------------------------------------------------
PILOT_NAME=xireactor-pilot
PILOT_REPO_REF=v0.2.0
PILOT_TENANTS=fr,apex-research

# --- Deployment mode ----------------------------------------------------------
# B = local-host (RC), E = tunnel (Cloudflare Tunnel + swarm)
DEPLOYMENT_MODE=B

# --- Network binding (§2.3) --------------------------------------------------
# On B: bind api to the Tailscale interface, NEVER 0.0.0.0.
# On E: leave empty — api runs behind CF Tunnel or CF Access.
API_HOST_BIND=100.96.54.170
API_PORT=8010

# Postgres is internal-only; POSTGRES_PORT is unused unless you explicitly
# expose db for debug via an override block.
POSTGRES_PORT=5432

# --- Volumes ------------------------------------------------------------------
POSTGRES_DATA_VOLUME=xireactor-pilot_pgdata

# --- Credentials (B: values here; E: Docker Swarm secrets) --------------------
# Postgres superuser — admin of the db container. Cross-tenant-privileged.
POSTGRES_PASSWORD=CHANGE_ME_SUPERUSER

# Audit role — BYPASSRLS, read-only session (§3.5). Cross-tenant-privileged.
# Same rotation cadence as POSTGRES_PASSWORD.
AUDIT_ROLE_PASSWORD=CHANGE_ME_AUDIT
AUDIT_ROLE_PASSWORD_SOURCE=env

# Anthropic API key for upstream's Tier-3 AI reviewer (cross-tenant writes only).
# Mount path inside the api container; real file lives in secrets/anthropic-api-key.
AI_REVIEWER_CREDS_SOURCE=bind
ANTHROPIC_API_KEY_PATH=/run/secrets/anthropic-api-key

# --- Tenant bearer tokens -----------------------------------------------------
# Generated out-of-band (see DEPLOY.md step 5). NOT in this file — lives in
# secrets/tenant-tokens.env and is distributed to each team's MCP config.

# --- WARP (unused for xireactor-pilot on B — pilot has no host networking) ---
WARP_CA_PATH=
