# apex-research container environment (*FR:Brunel*)
#
# Copy to .env and fill in values:
#   cp .env.example .env

# Required: GitHub PAT with read access to Eesti-Raudtee org repos
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: Anthropic API key for Claude Code CLI
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: PO's SSH public key (paste the full line from ~/.ssh/id_ed25519.pub)
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... michelek"

# Optional: Override default repo URLs
# REPO_URL=https://github.com/Eesti-Raudtee/apex-migration-research.git
# SOURCE_REPO_URL=https://github.com/Eesti-Raudtee/vjs_apex_apps.git

# Optional: Override default ports (useful if defaults conflict)
# SSH_PORT=2222
# DASHBOARD_PORT=5173

# Optional: Override team name
# TEAM_NAME=apex-research
