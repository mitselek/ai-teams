# hr-devs container — environment variables
# Copy to .env and fill in values before running docker compose.
# (*FR:Brunel*)

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub PAT with repo scope for Eesti-Raudtee org.
# Used for cloning hr-platform and dev-toolkit.
GITHUB_TOKEN=ghp_...

# Cloudflare API token + account ID.
# Required for Wrangler deploys and D1 database operations.
# Same token as used on local development machine.
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...

# Atlassian credentials for Jira MCP server.
ATLASSIAN_BASE_URL=https://eestiraudtee.atlassian.net
ATLASSIAN_EMAIL=mihkel.putrinsh@evr.ee
ATLASSIAN_API_TOKEN=...

# SSH public key for ai-teams user (port 2225).
# Generate: ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519_hr_devs -C "hr-devs-container"
# Then: cat ~/.ssh/id_ed25519_hr_devs.pub
SSH_PUBLIC_KEY=ssh-ed25519 AAAA...
# SSH_PUBLIC_KEY_2=ssh-ed25519 AAAA...   # optional: second key

# ── Optional ──────────────────────────────────────────────────────────────────

# Anthropic API key — leave blank to use OAuth (standard and recommended).
# OAuth credentials are stored in the hr-claude-home volume after first login.
ANTHROPIC_API_KEY=

# Git attribution inside container.
GIT_USER_NAME=hr-devs
GIT_USER_EMAIL=mihkel.putrinsh@evr.ee

# Override repo URLs if needed (e.g., for forks).
# REPO_URL=https://github.com/Eesti-Raudtee/hr-platform.git
# TOOLKIT_URL=https://github.com/Eesti-Raudtee/dev-toolkit.git

# Team name (default: hr-devs).
# TEAM_NAME=hr-devs
