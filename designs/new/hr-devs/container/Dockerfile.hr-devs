# Dockerfile.hr-devs (*FR:Brunel*)
#
# Extends ai-teams-claude:latest (ubuntu 24.04, nodejs 18, npm, git, gh, gosu, claude)
# with Node.js 22, Wrangler CLI, SSH server, tmux, locales, and Europe/Tallinn timezone.
#
# Differences from entu-research:
#   - npm retained (no pnpm)
#   - Wrangler CLI installed globally
#   - SSH port 2225 (apex=2222, polyphony=2223, entu=2224)
#   - No Playwright, no Python
#
# Named volumes (no host bind mounts except WARP CA + Dynamics data):
#   hr-claude-home  → /home/ai-teams/.claude    (Claude state + auto-memory)
#   hr-repo         → /home/ai-teams/workspace  (hr-platform + dev-toolkit repos)
#
# Workspace layout (cloned by entrypoint):
#   ~/workspace/hr-platform/   — main working repo (Eesti-Raudtee/hr-platform)
#   ~/workspace/dev-toolkit/   — MCP servers + standards (Eesti-Raudtee/dev-toolkit)
#
# Ports:
#   2225  — SSH (PO access, auto-tmux on login)
#   5178  — Vite dev server (configured via VITE_PORT env)
#   8787  — Wrangler dev server
#
# Build:
#   docker compose -f docker-compose.hr-devs.yml build
#
# Connect:
#   ssh -i ~/.ssh/id_ed25519_hr_devs -p 2225 ai-teams@<host>

FROM ai-teams-claude:latest

# ── Fix inherited apt sources ──────────────────────────────────────────────────
# Base image adds GitHub CLI apt repo with a key that may go stale.
# gh is already installed — remove the apt source, it's not needed.
RUN rm -f /etc/apt/sources.list.d/github-cli.list \
    && rm -f /usr/share/keyrings/githubcli-archive-keyring.gpg

# ── Node.js 22 LTS ────────────────────────────────────────────────────────────
# Base image has Node.js 18 from Ubuntu apt — too old for Claude Code and Wrangler.
# Download binary directly.
#
# WARP note: --insecure for nodejs.org download (WARP TLS interception at build time).
# Build-time only workaround; binary identified by versioned filename.
RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && curl --insecure -fsSL https://nodejs.org/dist/v22.14.0/node-v22.14.0-linux-x64.tar.gz \
       -o /tmp/node.tar.gz \
    && tar -xzf /tmp/node.tar.gz -C /usr/local --strip-components=1 \
    && rm /tmp/node.tar.gz \
    && node --version \
    && npm install -g npm@latest 2>&1 | tail -1 \
    && rm -rf /var/lib/apt/lists/*

# ── Timezone + SSH server + tmux + locales ────────────────────────────────────
# NOTE (#60): tmux is retained for HUMAN SSH session scaffolding only.
# Agent spawning is Agent-tool-based post-#60 — no tmux panes required.
# If the container drops PO SSH access, tmux can be removed from the apt line.
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        tzdata \
        openssh-server \
        tmux \
        locales \
    && rm -rf /var/lib/apt/lists/* \
    && sed -i 's/# en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen && locale-gen \
    && ln -snf /usr/share/zoneinfo/Europe/Tallinn /etc/localtime \
    && echo "Europe/Tallinn" > /etc/timezone \
    && dpkg-reconfigure -f noninteractive tzdata \
    && mkdir -p /run/sshd \
    && ssh-keygen -A \
    && sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?ChallengeResponseAuthentication.*/ChallengeResponseAuthentication no/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?UsePAM.*/UsePAM no/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?Port .*/Port 2225/' /etc/ssh/sshd_config \
    && echo 'Port 2225' >> /etc/ssh/sshd_config
ENV DEBIAN_FRONTEND=

# ── ai-teams SSH access ────────────────────────────────────────────────────────
# Unlock account for SSH pubkey auth.
# UsePAM=no rejects locked accounts (! in /etc/shadow) even for pubkey auth.
# '*' = no password (pubkey works). '!' = locked (all auth rejected).
RUN usermod -p '*' ai-teams \
    && mkdir -p /home/ai-teams/.ssh \
    && chmod 700 /home/ai-teams/.ssh \
    && chown 1000:1000 /home/ai-teams/.ssh

# ── Wrangler CLI ──────────────────────────────────────────────────────────────
# Install globally so agents can run `wrangler` from any directory.
# Pin after first successful deploy — use @latest for initial deployment.
RUN npm install -g wrangler@latest 2>&1 | tail -3 \
    && wrangler --version

# ── Native Claude Code install ────────────────────────────────────────────────
# Native install (~/.local/bin/claude) so auto-updates work without sudo.
# --insecure: WARP TLS interception at build time.
RUN gosu ai-teams bash -c 'curl --insecure -fsSL https://claude.ai/install.sh | bash' 2>&1 | tail -5

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint-hr-devs.sh /entrypoint-hr-devs.sh
RUN chmod +x /entrypoint-hr-devs.sh

WORKDIR /home/ai-teams/workspace

EXPOSE 2225 5178 8787

ENTRYPOINT ["/entrypoint-hr-devs.sh"]
CMD ["bash"]
